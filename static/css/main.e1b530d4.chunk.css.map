.splash-screen {
    width: 100%;
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #000;
    background-image: url('https://images.unsplash.com/photo-1485796826113-174aa68fd81b');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
  }
  
  .loading {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: #0f0;
    font-family: "Courier New", Courier, monospace;
    font-size: 2rem;
    text-shadow: 0 0 5px #0f0, 0 0 10px #0f0, 0 0 15px #0f0, 0 0 20px #0f0, 0 0 30px #0f0, 0 0 40px #0f0;
  }
  
  .loading-bar {
    width: 150px;
    height: 5px;
    background-color: #0f0;
    margin-bottom: 2rem;
    animation: loading-bar 1.5s infinite;
  }
  
  @keyframes loading-bar {
    0% {
      width: 0;
    }
    50% {
      width: 100%;
    }
    100% {
      width: 0;
    }
  }
  
  .loading p {
    margin: 0;
    font-size: 1.2rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    opacity: 0;
    animation: loading-text 5s ease-in-out forwards;
  }
  
  @keyframes loading-text {
    0% {
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
  